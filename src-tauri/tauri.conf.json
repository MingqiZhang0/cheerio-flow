{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cheerio Flow",
  "version": "0.1.0",
  "identifier": "com.cheerioflow.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cheerio Flow",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
